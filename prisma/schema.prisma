// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUM
enum Role {
  ADMIN
  HOD
  TEACHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Semester {
  first_semester
  second_semester
}

enum Year {
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
  FINAL
}


enum Month {
  JANUARY
  FEBRUARY
  MARCH
  APRIL
  MAY
  JUNE
  JULY
  AUGUST
  SEPTEMBER
  OCTOBER
  NOVEMBER
  DECEMBER
}

model Admin {
  id       String @id @default(uuid()) @db.Uuid
  username String @unique
  password String
  role     Role
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  password     String
  resetPasswordToken    String?
  resetPasswordExpireAt DateTime?
  fullName     String
  role         Role
  gender       Gender
  email        String   @unique
  phoneNumber  String

  // Belongs to one department
  departmentId String   @db.Uuid
  department   Department @relation("DepartmentUsers", fields: [departmentId], references: [id])

  // If this user is a HOD, this will point to that department
  hod        Department? @relation("DepartmentHod")

  classes      Class[]
  subjects     Subject[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Department {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  symbol   String
  logo     String?

  // One HOD per department
  hod      User?  @relation("DepartmentHod", fields: [hodId], references: [id])
  hodId    String? @unique @db.Uuid

  // Many users per department
  users    User[] @relation("DepartmentUsers")

  classes   Class[]
  students  Student[]
  subjects  Subject[]

  createdAt DateTime @default(now())
}

model Class {
  id       String   @id @default(uuid()) @db.Uuid
  name     String
  semester Semester
  year     Year

  userId  String? @db.Uuid
  user    User?   @relation(fields: [userId], references: [id])
  
  departmentId   String @db.Uuid
  department   Department   @relation(fields: [departmentId], references: [id])

  academicYearId String? @db.Uuid
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  students Student[]
  subjects Subject[]
  monthlyClassAttendance  MonthlyClassAttendance[]
}


model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean

  classes Class[]
}



model Student {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  rollNo      String  @unique
  dateOfBirth DateTime? @db.Date
  phoneNumber String
  gender      Gender
  email       String  @unique
  year        Year
  semester    Semester

  departmentId String @db.Uuid
  department Department @relation(fields: [departmentId], references: [id])

  classId      String @db.Uuid
  class      Class      @relation(fields: [classId], references: [id])

  dailyAttendance   DailyAttendance[]
  monthlySubAttendance    MonthlySubAttendance[]
}

model Subject {
  id      String @id @default(uuid()) @db.Uuid
  name    String
  subCode String
  roomName  String?

  departmentId String @db.Uuid
  department Department @relation(fields: [departmentId], references: [id])

  userId       String @db.Uuid
  user       User       @relation(fields: [userId], references: [id])

  classId      String @db.Uuid
  class      Class      @relation(fields: [classId], references: [id])

  dailyAttendance   DailyAttendance[]
  monthlySubAttendance MonthlySubAttendance[]
}

model DailyAttendance {
  id        String @id @default(uuid()) @db.Uuid

  day        Int
  month      Month
  times      Int
  totalTimes Int  

  studentId String @db.Uuid
  student Student @relation(fields: [studentId], references: [id])

  subjectId String @db.Uuid
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, day, month])
}

model MonthlySubAttendance {
  id                String  @id @default(uuid()) @db.Uuid
  times              Int
  totalTimes        Int
  status            Boolean

  student   Student? @relation(fields: [studentId], references: [id])
  studentId   String @db.Uuid
  subject    Subject @relation(fields: [subjectId], references: [id])
  subjectId   String @db.Uuid

  monthlyClassAttendance MonthlyClassAttendance? @relation(fields: [monthlyClassAttendanceId], references: [id])
  monthlyClassAttendanceId  String @db.Uuid

}

model MonthlyClassAttendance {
  id                     String  @id @default(uuid()) @db.Uuid
  monthlySubAttendanceId String[] @db.Uuid
  totalTimes             Int
  status                 Boolean

  class Class? @relation(fields: [classId], references: [id])
  classId   String @db.Uuid
  
  monthlySubAttendance  MonthlySubAttendance[]
}
