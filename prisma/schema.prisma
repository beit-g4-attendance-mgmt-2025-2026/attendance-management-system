// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUM
enum Role {
  ADMIN
  HOD
  TEACHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Semester {
  first_semester
  second_semester
}

enum Year {
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
  FINAL
}


enum Month {
  JANUARY
  FEBRUARY
  MARCH
  APRIL
  MAY
  JUNE
  JULY
  AUGUST
  SEPTEMBER
  OCTOBER
  NOVEMBER
  DECEMBER
}

model Admin {
  id       String @id @default(uuid()) @db.Uuid
  username String @unique
  password String
  role     Role
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  username     String      @unique
  password     String
  resetPasswordToken  String?
  resetPasswordExpireAt   DateTime?
  fullName     String
  role         Role
  gender       Gender
  email        String   @unique
  phoneNumber  String

  departmentId String      @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id])

  class        Class?

  subjects     Subject[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Class {
  id       String   @id @default(uuid()) @db.Uuid
  name     String
  semester Semester
  year     Year

  userId  String  @unique @db.Uuid
  user    User  @relation(fields: [userId], references: [id])
  
  departmentId   String @db.Uuid
  department   Department   @relation(fields: [departmentId], references: [id])

  academicYearId String? @db.Uuid
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  students Student[]
  subjects Subject[]
  monthlyClassAttendance  MonthlyClassAttendance[]
}

model Department {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  symbol   String

  users User[]
  classes      Class[]
  students Student[]
  subjects     Subject[]

  createdAt DateTime @default(now())

}

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean

  classes Class[]
}



model Student {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  rollNo      String  @unique
  phoneNumber Int
  gender      Gender
  email       String  @unique
  year        Year
  semester    Semester

  departmentId String @db.Uuid
  department Department @relation(fields: [departmentId], references: [id])

  classId      String @db.Uuid
  class      Class      @relation(fields: [classId], references: [id])

  dailyAttendance   DailyAttendance[]
  monthlySubAttendance    MonthlySubAttendance[]
}

model Subject {
  id      String @id @default(uuid()) @db.Uuid
  name    String
  subCode String

  departmentId String @db.Uuid
  department Department @relation(fields: [departmentId], references: [id])

  userId       String @db.Uuid
  user       User       @relation(fields: [userId], references: [id])

  classId      String @db.Uuid
  class      Class      @relation(fields: [classId], references: [id])

  dailyAttendance   DailyAttendance[]
  monthlySubAttendance MonthlySubAttendance[]
}

model DailyAttendance {
  id        String @id @default(uuid()) @db.Uuid

  day        Int
  month      Month
  times      Int
  totalTimes Int  

  studentId String @db.Uuid
  student Student @relation(fields: [studentId], references: [id])

  subjectId String @db.Uuid
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, day, month])
}

model MonthlySubAttendance {
  id                String  @id @default(uuid()) @db.Uuid
  times              Int
  totalTimes        Int
  status            Boolean

  student   Student? @relation(fields: [studentId], references: [id])
  studentId   String
  subject    Subject @relation(fields: [subjectId], references: [id])
  subjectId   String

  monthlyClassAttendance MonthlyClassAttendance? @relation(fields: [monthlyClassAttendanceId], references: [id])
  monthlyClassAttendanceId  String

}

model MonthlyClassAttendance {
  id                     String  @id @default(uuid()) @db.Uuid
  monthlySubAttendanceId String[] @db.Uuid
  totalTimes             Int
  status                 Boolean

  class Class? @relation(fields: [classId], references: [id])
  classId   String
  
  monthlySubAttendance  MonthlySubAttendance[]
}
